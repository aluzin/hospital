        {
          "name": "Search BirthDate And Or With Pagination",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/patients?birthDate=eq2024-01-12,eq2024-01-13&birthDate=eq2024-01-13,eq2024-01-14&skip=0&take=1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "patients"
              ],
              "query": [
                {
                  "key": "birthDate",
                  "value": "eq2024-01-12,eq2024-01-13"
                },
                {

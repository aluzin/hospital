        {
          "name": "Search BirthDate Approximate",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/patients?birthDate=ap2024-01-13",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "patients"
              ],
              "query": [
                {
                  "key": "birthDate",
                  "value": "ap2024-01-13"

{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/hospital-.log",
          "rollingInterval": "Day",
          "shared": true,
          "retainedFileCountLimit": 14
        }
      }
    ]
  },
  "Database": {
    "MigrateOnStartup": true
  },
  "ConnectionStrings": {
    "HospitalDatabase": "Host=localhost;Port=5432;Database=hospital;Username=postgres;Password=postgres"
  },
  "AllowedHosts": "*"
}
